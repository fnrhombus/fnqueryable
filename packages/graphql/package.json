{
  "name": "@fnqueryable/graphql",
  "version": "0.1.0",
  "description": "GraphQL query provider for fnqueryable. Translate expression trees to GraphQL queries.",
  "license": "MIT",
  "author": "fnrhombus",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnrhombus/fnqueryable",
    "directory": "packages/graphql"
  },
  "bugs": {
    "url": "https://github.com/fnrhombus/fnqueryable/issues"
  },
  "homepage": "https://github.com/fnrhombus/fnqueryable#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fnqueryable": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
