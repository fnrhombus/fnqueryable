{
  "name": "fnqueryable",
  "version": "0.1.0",
  "description": "IQueryable for TypeScript. Write lambdas, get expression trees. The foundation for type-safe query translation.",
  "keywords": [
    "queryable",
    "iqueryable",
    "linq",
    "expression-tree",
    "lambda",
    "query",
    "sql",
    "odata"
  ],
  "license": "MIT",
  "author": "fnrhombus",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnrhombus/fnqueryable"
  },
  "bugs": {
    "url": "https://github.com/fnrhombus/fnqueryable/issues"
  },
  "homepage": "https://github.com/fnrhombus/fnqueryable#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "acorn": "^8.14.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
